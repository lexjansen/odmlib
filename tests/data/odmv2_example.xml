        <ItemDef OID="IT.ALBUMIN_BLOOD_UNIT" Name="Unit for blood albumin test" DataType="text">
            <CodeListRef CodeListOID="CL.ALBUMIN_BLOOD_UNIT"/>
        </ItemDef>
